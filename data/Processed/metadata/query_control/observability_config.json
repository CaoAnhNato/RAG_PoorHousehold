{
  "version": "1.0",
  "log_dir": "data/Processed/logs",
  "trace_dir": "data/Processed/logs/traces",
  "enable_jsonl_logs": true,
  "enable_latency_metrics": true,
  "enable_error_logs": true,
  "enable_debug_payloads": true,
  "redact_fields": [
    "full_raw_rows",
    "stack_trace"
  ],
  "log_files": {
    "query_events": "query_events.jsonl",
    "errors": "errors.jsonl",
    "latency": "latency.jsonl"
  }
}
